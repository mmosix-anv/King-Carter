# ── Proxy config ──────────────────────────────────────────────
PORT=3001
LIMO_ALIAS=kingandcarter
CACHE_TTL=300
TRUST_PROXY=true

# Default redirect destination after a successful login
# Can be overridden per-embed with ?redirect=https://yourdomain.com/page
LOGIN_REDIRECT_URL=https://yourdomain.com

# Secret for the /booking/refresh cache-bust endpoint
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REFRESH_SECRET=replace_with_a_long_random_string
