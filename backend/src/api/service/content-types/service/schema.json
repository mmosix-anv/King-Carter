{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Services"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "content-manager": {
      "visible": true
    },
    "content-type-builder": {
      "visible": true
    }
  },
  "attributes": {
    "serviceId": {
      "type": "uid",
      "required": true,
      "unique": true,
      "minLength": 1
    },
    "heroTitle": {
      "type": "string",
      "required": true,
      "minLength": 1
    },
    "heroTagline": {
      "type": "text",
      "required": true,
      "minLength": 1
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "featuredImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "json",
      "required": true
    },
    "highlights": {
      "type": "json",
      "required": true
    },
    "images": {
      "type": "media",
      "multiple": true,
      "required": true,
      "allowedTypes": ["images"]
    },
    "cta": {
      "type": "json",
      "required": true
    }
  }
}
